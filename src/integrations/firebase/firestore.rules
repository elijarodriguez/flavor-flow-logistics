rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return exists(/databases/$(database)/documents/user_roles/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.role == 'admin';
    }

    // Products collection: public read, admin write
    match /products/{document=**} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && isAdmin();
    }

    // Orders collection: admin read/write
    match /orders/{document=**} {
      allow read, write: if request.auth != null && isAdmin();
    }

    // User roles: authenticated users can read their own, admins can read all
    match /user_roles/{uid} {
      allow read: if request.auth.uid == uid || isAdmin();
      allow write: if request.auth != null && isAdmin();
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
